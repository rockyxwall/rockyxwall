---
import '../styles/globals.css';
import '@fontsource-variable/geist';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Blog | Daniel Garcia";
const description = "Thoughts on software engineering, AI, and entrepreneurship.";

const posts = [
  {
    title: "How I reached $60K ARR as a Solo Founder",
    excerpt: "Lessons learned from building and scaling my first successful SaaS business.",
    date: "2024-03-15",
    readingTime: "12 min"
  },
  {
    title: "Why Industrial Engineers make great Developers",
    excerpt: "The crossover between systems thinking and software architecture.",
    date: "2024-02-28",
    readingTime: "8 min"
  },
  {
    title: "The Future of AI Automation in 2024",
    excerpt: "What to expect from the next wave of LLM-powered tools.",
    date: "2024-01-10",
    readingTime: "15 min"
  }
];
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <meta name="description" content={description} />
	</head>
	<body class="bg-background text-foreground font-sans antialiased min-h-screen flex flex-col">
    <Header />

    <main class="flex-1 container max-w-screen-md mx-auto px-4 py-12 md:py-24 space-y-12">
      <section class="space-y-4">
        <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
        <p class="text-foreground/60 leading-relaxed">
          Sharing my thoughts on building products, engineering challenges, and the journey of an indie hacker.
        </p>
      </section>

      <section class="space-y-8">
        {posts.map((post) => (
          <article class="group relative flex flex-col space-y-2">
            <div class="flex items-center gap-4 text-xs text-foreground/40 font-medium">
              <time dateTime={post.date}>{post.date}</time>
              <span>•</span>
              <span>{post.readingTime} read</span>
            </div>
            <h2 class="text-xl font-bold tracking-tight group-hover:text-primary transition-colors">
              <a href="#">{post.title}</a>
            </h2>
            <p class="text-sm text-foreground/60 leading-relaxed max-w-2xl">
              {post.excerpt}
            </p>
          </article>
        ))}
      </section>
    </main>

    <Footer />
	</body>
</html>
