---
import '../styles/globals.css';
import '@fontsource-variable/geist';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>rockyxwall | Portfolio</title>
	</head>
	<body class="bg-zinc-950 text-zinc-100 min-h-screen flex items-center justify-center font-sans">
		<main class="max-w-2xl w-full p-8 space-y-6">
			<header class="space-y-2">
				<h1 class="text-4xl font-bold tracking-tight">
					hi, i'm <span class="text-blue-500">rockyxwall</span>!
				</h1>
				<p class="text-xl text-zinc-400">
					welcome to my profile
				</p>
			</header>

			<section class="p-6 rounded-2xl bg-zinc-900/50 border border-zinc-800 backdrop-blur-sm">
				<p class="text-lg leading-relaxed">
					I'm a <code class="bg-zinc-800 px-1.5 py-0.5 rounded text-zinc-300">student</code> and 
					<code class="bg-zinc-800 px-1.5 py-0.5 rounded text-zinc-300">tech hobbyist</code> 
					currently learning web development.
				</p>
			</section>

			<footer class="pt-8 text-sm text-zinc-500">
				<p>_links-under-construction_</p>
			</footer>
		</main>
	</body>
</html>
